# Server-mode config for conformance testing.
# Full TUN tunnel with management-client-auth so the test harness
# must approve every connecting client via the management interface.
mode server
topology subnet
dev tun
proto udp
port 1194

server 10.8.0.0 255.255.255.0

ca   /etc/openvpn/ca.crt
cert /etc/openvpn/server.crt
key  /etc/openvpn/server.key
dh   none

management 0.0.0.0 7506 /etc/openvpn/mgmt-pw.txt
management-hold
management-client-auth

keepalive 10 60
persist-key
persist-tun
verb 4
