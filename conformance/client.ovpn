# Client config for conformance testing.
# Connects to the server container and retries until it succeeds.
client
dev tun
proto udp
remote openvpn-server 1194
resolv-retry infinite
nobind

ca   /etc/openvpn/ca.crt
cert /etc/openvpn/client.crt
key  /etc/openvpn/client.key
auth-user-pass /etc/openvpn/auth.txt

persist-key
persist-tun
verb 4
connect-retry 1 1
connect-retry-max unlimited
