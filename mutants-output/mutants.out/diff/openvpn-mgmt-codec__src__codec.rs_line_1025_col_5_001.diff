 fn parse_bytecount(payload: &str) -> Option<Notification> {
     let (a, b) = payload.split_once(',')?;
     Some(Notification::ByteCount {
         bytes_in: parse_field(a, "bytecount bytes_in")?,
         bytes_out: parse_field(b, "bytecount bytes_out")?,
     })
