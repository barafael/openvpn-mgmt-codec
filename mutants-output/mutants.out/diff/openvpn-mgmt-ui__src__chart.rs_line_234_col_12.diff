 /// Format bytes/sec in a compact human-readable form for axis labels.
 fn format_rate(bps: f64) -> String {
     const KIB: f64 = 1024.0;
     const MIB: f64 = 1024.0 * KIB;
 
-    if bps >= MIB {
+    if bps < /* ~ changed by cargo-mutants ~ */ MIB {
         format!("{:.0}M", bps / MIB)
     } else if bps >= KIB {
         format!("{:.0}K", bps / KIB)
     } else {
         format!("{:.0}B", bps)
     }
 }
 
